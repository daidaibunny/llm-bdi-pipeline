# Shared OpenAI-compatible language-model API configuration
LANGUAGE_MODEL_API_KEY=
LANGUAGE_MODEL_BASE_URL=https://api.deepseek.com
LANGUAGE_MODEL_MODEL=deepseek-v4-pro

# Optional NL-to-LTLf generation overrides
LTLF_GENERATION_TIMEOUT=1000
LTLF_GENERATION_MAX_TOKENS=12000
LTLF_GENERATION_SESSION_ID=ltlf-generation

# Optional HTN method synthesis overrides
METHOD_SYNTHESIS_TIMEOUT=2400
METHOD_SYNTHESIS_MAX_TOKENS=144000
METHOD_SYNTHESIS_SESSION_ID=method-synthesis

# Optional direct primitive-plan generation overrides
DIRECT_PLAN_GENERATION_TIMEOUT=1800
DIRECT_PLAN_GENERATION_MAX_TOKENS=24000
DIRECT_PLAN_GENERATION_SESSION_ID=direct-plan-generation

# Optional: evaluation runtime domain source
# benchmark = use the benchmark domain as the evaluation base domain
# generated = materialize a generated evaluation domain from the stored M artifact
EVALUATION_DOMAIN_SOURCE=benchmark
