# Shared OpenAI-compatible language-model API configuration.
# Default points at Aliyun DashScope's OpenAI-compatible endpoint. Set the API key
# below; override the model/base URL for any other SOTA OpenAI-compatible provider.
LANGUAGE_MODEL_API_KEY=
LANGUAGE_MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LANGUAGE_MODEL_MODEL=qwen-max

# Optional NL-to-LTLf generation overrides.
# LTLF_GENERATION_API_KEY / LTLF_GENERATION_BASE_URL / LTLF_GENERATION_MODEL fall
# back to the LANGUAGE_MODEL_* values above when unset.
LTLF_GENERATION_API_KEY=
LTLF_GENERATION_MODEL=
LTLF_GENERATION_TIMEOUT=1000
LTLF_GENERATION_MAX_TOKENS=12000
LTLF_GENERATION_SESSION_ID=ltlf-generation
