    "tests": "PYTHONDONTWRITEBYTECODE=1 uv run pytest -p no:cacheprovider -q",
    "paper": "cd latex_code/aamas_method_paper && latexmk -pdf -interaction=nonstopmode -halt-on-error -outdir=build main.tex"
